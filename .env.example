# ============================================================
# VaultIQ — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ============================================================

# --- Database ---
# PostgreSQL connection string (Render / Supabase / local)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/vaultiq?schema=public"

# --- Authentication ---
# A long random string; generate with: openssl rand -hex 64
JWT_SECRET="your-super-secret-jwt-key-minimum-32-chars"
# Access token expiry (e.g. 15m, 1h)
JWT_EXPIRY="15m"

# --- Azure AD SSO (production) ---
AZURE_TENANT_ID="your-azure-tenant-id"
AZURE_CLIENT_ID="your-azure-client-id"
AZURE_CLIENT_SECRET="your-azure-client-secret"

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- App ---
# Port the NestJS backend listens on
PORT=4000
# Allowed CORS origin (must match your frontend URL exactly)
FRONTEND_URL="http://localhost:3000"
# Set to 'development' locally, 'production' in deploy
NODE_ENV="development"

# --- Frontend ---
# Public API base URL consumed by Next.js
NEXT_PUBLIC_API_URL="http://localhost:4000"
