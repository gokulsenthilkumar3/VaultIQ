generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

// NOTE: SQLite does not natively support enum types.
// These are represented as String columns with application-level validation.
// When migrating to PostgreSQL, convert these to proper Prisma enum types.

// UserRole    : ADMIN | MANAGER | USER
// AssetStatus : AVAILABLE | ASSIGNED | MAINTENANCE | RETIRED
// MaintenanceStatus: OPEN | IN_PROGRESS | COMPLETED | CANCELLED
// MaintenancePriority: LOW | MEDIUM | HIGH | CRITICAL

model User {
  id               String            @id @default(uuid())
  email            String            @unique
  fullName         String
  role             String            @default("USER")
  azureId          String            @unique
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  assignments      AssetAssignment[]
  auditLogs        AuditLog[]
  tickets          HelpdeskTicket[]
}

model Asset {
  id               String            @id @default(uuid())
  tagId            String            @unique // QR/Barcode content
  serialNumber     String            @unique
  modelName        String
  typeId           String
  locationId       String
  status           String            @default("AVAILABLE")
  purchasePrice    Float
  purchaseDate     DateTime
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  type             AssetType         @relation(fields: [typeId], references: [id])
  location         Location          @relation(fields: [locationId], references: [id])
  assignments      AssetAssignment[]
  maintenance      MaintenanceRecord[]
  tickets          HelpdeskTicket[]
  auditLogs        AuditLog[]
}

model AssetAssignment {
  id               String    @id @default(uuid())
  assetId          String
  userId           String
  assignedAt       DateTime  @default(now())
  returnedAt       DateTime?
  signatureBlob    String?   // Base64 or URL
  conditionNotes   String?

  asset            Asset     @relation(fields: [assetId], references: [id])
  user             User      @relation(fields: [userId], references: [id])
}

model MaintenanceRecord {
  id               String    @id @default(uuid())
  assetId          String
  issueType        String
  description      String
  // priority is a first-class field (LOW | MEDIUM | HIGH | CRITICAL).
  // Replaces the previous workaround of embedding priority in technicianNotes.
  priority         String    @default("MEDIUM")
  status           String    @default("OPEN")
  scheduledDate    DateTime
  completedAt      DateTime?
  technicianNotes  String?

  asset            Asset     @relation(fields: [assetId], references: [id])
}

model AssetType {
  id               String    @id @default(uuid())
  name             String    @unique
  lifespanYears    Int
  assets           Asset[]
}

model Location {
  id               String    @id @default(uuid())
  name             String    @unique
  address          String
  assets           Asset[]
}

model AuditLog {
  id                String    @id @default(uuid())
  action            String
  assetId           String?
  userId            String
  details           String
  timestamp         DateTime  @default(now())
  blockHash         String?
  previousBlockHash String?

  user             User      @relation(fields: [userId], references: [id])
  asset            Asset?    @relation(fields: [assetId], references: [id])
}

model HelpdeskTicket {
  id               String    @id @default(uuid())
  title            String
  description      String
  status           String    @default("OPEN")
  priority         String    @default("MEDIUM")
  userId           String
  assetId          String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user             User      @relation(fields: [userId], references: [id])
  asset            Asset?    @relation(fields: [assetId], references: [id])
}

// ---------------------------------------------------------------------------
// RefreshToken — persisted for server-side revocation (rotation security)
// ---------------------------------------------------------------------------
model RefreshToken {
  id          String   @id @default(uuid())
  userId      String
  tokenHash   String   @unique  // SHA-256 hash of the raw refresh token
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  revoked     Boolean  @default(false)

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
