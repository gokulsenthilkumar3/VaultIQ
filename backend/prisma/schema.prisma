generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id                String            @id @default(uuid())
  email             String            @unique
  fullName          String
  role              String            @default("USER")
  azureId           String            @unique
  department        String?
  employeeId        String?           @unique
  hireDate          DateTime?
  performanceRating Int? // e.g., 1 to 5
  dateOfBirth       DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  assignments       AssetAssignment[]
  auditLogs         AuditLog[]
  tickets           HelpdeskTicket[]
  leaveRequests     LeaveRequest[]
  payslips          Payslip[]
  attendanceLogs    AttendanceLog[]
  ticketComments    TicketComment[]
  roomBookings      RoomBooking[]
  deskBookings      DeskBooking[]
  purchaseRequests  PurchaseRequest[]
  assignedTasks     WorkflowTask[] @relation("AssignedTo")
  targetedTasks     WorkflowTask[] @relation("TargetUser")
  conductedAudits   ComplianceAudit[]
}

model Asset {
  id            String   @id @default(uuid())
  tagId         String   @unique // QR/Barcode content
  serialNumber  String   @unique
  modelName     String
  typeId        String
  locationId    String
  status        String   @default("AVAILABLE")
  purchasePrice Float
  purchaseDate  DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  type        AssetType           @relation(fields: [typeId], references: [id])
  location    Location            @relation(fields: [locationId], references: [id])
  assignments AssetAssignment[]
  maintenance MaintenanceRecord[]
  tickets     HelpdeskTicket[]
  auditLogs   AuditLog[]
}

model AssetAssignment {
  id             String    @id @default(uuid())
  assetId        String
  userId         String
  assignedAt     DateTime  @default(now())
  returnedAt     DateTime?
  signatureBlob  String? // Base64 or URL
  conditionNotes String?

  asset Asset @relation(fields: [assetId], references: [id])
  user  User  @relation(fields: [userId], references: [id])
}

model MaintenanceRecord {
  id              String    @id @default(uuid())
  assetId         String
  issueType       String
  description     String
  status          String    @default("OPEN")
  scheduledDate   DateTime
  completedAt     DateTime?
  technicianNotes String?

  asset Asset @relation(fields: [assetId], references: [id])
}

model AssetType {
  id            String  @id @default(uuid())
  name          String  @unique
  lifespanYears Int
  assets        Asset[]
}

model Location {
  id           String        @id @default(uuid())
  name         String        @unique
  address      String
  assets       Asset[]
  meetingRooms MeetingRoom[]
  desks        Desk[]
}

model AuditLog {
  id                String   @id @default(uuid())
  action            String
  assetId           String?
  userId            String
  details           String
  timestamp         DateTime @default(now())
  blockHash         String?
  previousBlockHash String?

  user  User   @relation(fields: [userId], references: [id])
  asset Asset? @relation(fields: [assetId], references: [id])
}

model HelpdeskTicket {
  id          String   @id @default(uuid())
  title       String
  description String
  status      String   @default("OPEN")
  priority    String   @default("MEDIUM")
  userId      String
  assetId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id])
  asset Asset? @relation(fields: [assetId], references: [id])
  comments TicketComment[]
}

model CompanyUpdate {
  id      String   @id @default(uuid())
  title   String
  content String
  type    String // 'announcement', 'update', 'news'
  author  String
  date    DateTime @default(now())
}

model LeaveRequest {
  id        String   @id @default(uuid())
  userId    String
  type      String // 'annual', 'sick', 'outdoor', 'ot'
  startDate DateTime
  endDate   DateTime
  days      Int
  status    String   @default("PENDING") // 'PENDING', 'APPROVED', 'REJECTED'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Payslip {
  id     String   @id @default(uuid())
  userId String
  period String
  amount String
  status String   @default("PAID")
  date   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Quote {
  id      String @id @default(uuid())
  content String
}

model AttendanceLog {
  id       String    @id @default(uuid())
  userId   String
  clockIn  DateTime  @default(now())
  clockOut DateTime?

  user User @relation(fields: [userId], references: [id])
}

// ==========================================
// EXPANSION MODULES (Helpdesk, Facilities, Procurement, Workflows, Compliance)
// ==========================================

model TicketComment {
  id        String   @id @default(uuid())
  ticketId  String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  ticket HelpdeskTicket @relation(fields: [ticketId], references: [id])
  author User           @relation(fields: [authorId], references: [id])
}

model MeetingRoom {
  id         String   @id @default(uuid())
  name       String   @unique
  capacity   Int
  locationId String
  status     String   @default("AVAILABLE")

  location Location      @relation(fields: [locationId], references: [id])
  bookings RoomBooking[]
}

model RoomBooking {
  id        String   @id @default(uuid())
  roomId    String
  userId    String
  startTime DateTime
  endTime   DateTime
  purpose   String?

  room MeetingRoom @relation(fields: [roomId], references: [id])
  user User        @relation(fields: [userId], references: [id])
}

model Desk {
  id         String   @id @default(uuid())
  label      String   @unique
  locationId String
  isHotDesk  Boolean  @default(true)
  status     String   @default("AVAILABLE")

  location Location      @relation(fields: [locationId], references: [id])
  bookings DeskBooking[]
}

model DeskBooking {
  id        String   @id @default(uuid())
  deskId    String
  userId    String
  date      DateTime
  startTime DateTime?
  endTime   DateTime?

  desk Desk @relation(fields: [deskId], references: [id])
  user User @relation(fields: [userId], references: [id])
}

model Vendor {
  id           String   @id @default(uuid())
  name         String   @unique
  contactEmail String?
  contactPhone String?
  website      String?

  purchaseRequests PurchaseRequest[]
}

model PurchaseRequest {
  id            String   @id @default(uuid())
  requestedById String
  vendorId      String?
  title         String
  description   String
  expectedCost  Float
  status        String   @default("PENDING") // PENDING, APPROVED, REJECTED, ORDERED
  createdAt     DateTime @default(now())

  requestedBy User    @relation(fields: [requestedById], references: [id])
  vendor      Vendor? @relation(fields: [vendorId], references: [id])
}

model WorkflowTask {
  id           String   @id @default(uuid())
  title        String
  type         String   // ONBOARD, OFFBOARD, AUDIT
  targetUserId String?
  assignedToId String
  status       String   @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED
  dueDate      DateTime?
  createdAt    DateTime @default(now())

  targetUser User? @relation("TargetUser", fields: [targetUserId], references: [id])
  assignedTo User  @relation("AssignedTo", fields: [assignedToId], references: [id])
}

model ComplianceAudit {
  id           String   @id @default(uuid())
  type         String   // SOC2, ISO27001, INTERNAL
  targetId     String?  // Can be an Asset ID or Location ID
  conductedById String
  findings     String?
  status       String   @default("SCHEDULED") // SCHEDULED, IN_PROGRESS, COMPLETED
  date         DateTime

  conductedBy User @relation(fields: [conductedById], references: [id])
}
